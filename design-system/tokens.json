{
  "$schema": "https://tokens-studio.com/schema.json",
  "$comment": [
    "v0.10-P2-A · Phase A of the DESIGN-SYSTEM-ROADMAP.md uplift.",
    "",
    "Single source of truth for every brand / surface / typography",
    "decision made anywhere in PixCull's three rendering targets:",
    "  • Web   — results.html + upload.html + admin/*",
    "  • iOS   — mobile/PixCullCompanion/Sources/...",
    "  • PDF   — cli_audit --executive + executive_pdf.py",
    "",
    "Editable by designers via Tokens Studio (a Figma plugin) — the",
    "JSON shape mirrors their schema.  Engineers consume the output",
    "of `python scripts/build_design_tokens.py` which converts this",
    "file into the three platform-specific targets at build time.",
    "",
    "DO NOT edit the generated *.css / *.swift files — edits will be",
    "overwritten on the next build.  Edit THIS file."
  ],
  "version": "1.0.0",
  "$lastUpdated": "v0.10-P2-A",
  "color": {
    "brand": {
      "indigo":   { "value": "#6E56CF", "type": "color",
        "description": "Brand gradient stop 1 — used on logo, primary CTAs, score radial, .ai-num text fill" },
      "violet":   { "value": "#A855F7", "type": "color",
        "description": "Brand gradient stop 2 — middle of indigo→pink ramp" },
      "pink":     { "value": "#EC4899", "type": "color",
        "description": "Brand gradient stop 3 — accent + share-link badges" },
      "gradient": {
        "value": "linear-gradient(135deg, #6E56CF 0%, #A855F7 55%, #EC4899 100%)",
        "type": "gradient",
        "description": "The signature gradient. Avoid using this anywhere except v0.9-defined signature surfaces (logo, primary CTA, hero numerals, loading bar)."
      }
    },
    "surface": {
      "bg":          { "value": "#1a1c20", "type": "color",
        "description": "App background — workspace gray (v0.5 LR-grade)" },
      "bg-card":     { "value": "#23262c", "type": "color",
        "description": "Card tile surface" },
      "bg-card-hi":  { "value": "#2a2e35", "type": "color",
        "description": "Card hover / raised state" },
      "surface-2":   { "value": "#2a2e35", "type": "color",
        "description": "Panel / sidebar / inspector surface" },
      "surface-3":   { "value": "#34383f", "type": "color",
        "description": "Inset blocks (e.g. inspector cell, code blocks)" },
      "chrome":      { "value": "#14161a", "type": "color",
        "description": "Sticky chrome (workspace bar, modal header)" }
    },
    "fg": {
      "primary":   { "value": "#f1f3f7", "type": "color" },
      "secondary": { "value": "#c5cad4", "type": "color" },
      "muted":     { "value": "#a8b2c1", "type": "color" },
      "muted-soft":{ "value": "#7a8696", "type": "color" }
    },
    "border": {
      "default": { "value": "#232830", "type": "color" },
      "hi":      { "value": "#2f3742", "type": "color" }
    },
    "accent": {
      "default":     { "value": "#6366f1", "type": "color" },
      "hi":          { "value": "#818cf8", "type": "color" },
      "soft":        { "value": "rgba(99,102,241,0.14)", "type": "color" },
      "glow":        { "value": "rgba(99,102,241,0.40)", "type": "color" },
      "focus-ring":  { "value": "rgba(129,140,248,0.55)", "type": "color" }
    },
    "semantic": {
      "success":        { "value": "#34d399", "type": "color" },
      "success-tint":   { "value": "rgba(52,211,153,0.14)", "type": "color" },
      "success-border": { "value": "rgba(52,211,153,0.40)", "type": "color" },
      "warn":           { "value": "#fbbf24", "type": "color" },
      "warn-tint":      { "value": "rgba(251,191,36,0.14)", "type": "color" },
      "warn-border":    { "value": "rgba(251,191,36,0.40)", "type": "color" },
      "danger":         { "value": "#ef6363", "type": "color" },
      "danger-tint":    { "value": "rgba(239,99,99,0.14)", "type": "color" },
      "danger-border":  { "value": "rgba(239,99,99,0.40)", "type": "color" },
      "info":           { "value": "#38bdf8", "type": "color" },
      "info-tint":      { "value": "rgba(56,189,248,0.14)", "type": "color" },
      "info-border":    { "value": "rgba(56,189,248,0.40)", "type": "color" },
      "neutral":        { "value": "#a8b2c1", "type": "color" },
      "neutral-tint":   { "value": "rgba(168,178,193,0.10)", "type": "color" },
      "neutral-border": { "value": "rgba(168,178,193,0.30)", "type": "color" }
    },
    "decision": {
      "$comment": "Aliases to semantic.* — keep + maybe + cull badges all over the UI key on these names",
      "keep":      { "value": "{color.semantic.success}", "type": "color" },
      "maybe":     { "value": "{color.semantic.warn}",    "type": "color" },
      "cull":      { "value": "{color.semantic.danger}",  "type": "color" },
      "keep-cb":   { "value": "#0ea5e9", "type": "color", "description": "P-UX-23 color-blind palette" },
      "maybe-cb":  { "value": "#f59e0b", "type": "color" },
      "cull-cb":   { "value": "#d946ef", "type": "color" }
    }
  },
  "font": {
    "family": {
      "display": {
        "value": "Inter Display, Inter, -apple-system, BlinkMacSystemFont, Segoe UI Variable, Segoe UI, PingFang SC, Microsoft Yahei UI, sans-serif",
        "type": "fontFamily"
      },
      "body": {
        "value": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI Variable, Segoe UI, PingFang SC, Microsoft Yahei UI, sans-serif",
        "type": "fontFamily"
      },
      "mono": {
        "value": "ui-monospace, SF Mono, JetBrains Mono, Menlo, monospace",
        "type": "fontFamily"
      },
      "serif": {
        "value": "Charter, Iowan Old Style, PT Serif, Source Serif Pro, Source Serif 4, Cambria, Georgia, Songti SC, STZhongsong, serif",
        "type": "fontFamily",
        "description": "v0.9-P0-3 serif accent — used for hero numerals, executive PDF cover, brand wordmark"
      }
    },
    "size": {
      "hero":  { "value": "28px",   "type": "fontSize" },
      "h2":    { "value": "18px",   "type": "fontSize" },
      "h3":    { "value": "14px",   "type": "fontSize" },
      "body":  { "value": "13px",   "type": "fontSize" },
      "small": { "value": "11.5px", "type": "fontSize" },
      "tiny":  { "value": "10.5px", "type": "fontSize" }
    },
    "lineHeight": {
      "tight":  { "value": "1.25", "type": "lineHeight" },
      "normal": { "value": "1.55", "type": "lineHeight" },
      "loose":  { "value": "1.7",  "type": "lineHeight" }
    }
  },
  "spacing": {
    "1": { "value": "4px",  "type": "spacing" },
    "2": { "value": "8px",  "type": "spacing" },
    "3": { "value": "12px", "type": "spacing" },
    "4": { "value": "16px", "type": "spacing" },
    "5": { "value": "20px", "type": "spacing" },
    "6": { "value": "24px", "type": "spacing" },
    "7": { "value": "32px", "type": "spacing" },
    "8": { "value": "48px", "type": "spacing" }
  },
  "radius": {
    "sm":   { "value": "4px",   "type": "borderRadius" },
    "md":   { "value": "6px",   "type": "borderRadius" },
    "lg":   { "value": "10px",  "type": "borderRadius" },
    "xl":   { "value": "14px",  "type": "borderRadius" },
    "pill": { "value": "999px", "type": "borderRadius" }
  },
  "shadow": {
    "sm": { "value": "0 1px 2px rgba(0,0,0,0.30)",   "type": "boxShadow" },
    "md": { "value": "0 4px 12px rgba(0,0,0,0.40)",  "type": "boxShadow" },
    "lg": { "value": "0 12px 32px rgba(0,0,0,0.50)", "type": "boxShadow" },
    "xl": { "value": "0 24px 56px rgba(0,0,0,0.55)", "type": "boxShadow" }
  },
  "motion": {
    "duration": {
      "fast":   { "value": "120ms", "type": "duration" },
      "normal": { "value": "220ms", "type": "duration" },
      "slow":   { "value": "320ms", "type": "duration" }
    },
    "ease": {
      "out": {
        "value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "type": "cubicBezier",
        "description": "v0.9-P0-1 signature soft-bounce — 6% overshoot. The 'PixCull pixcull-overshoot' curve, used on 200+ transitions across the app."
      },
      "out-flat": {
        "value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "type": "cubicBezier",
        "description": "Flat-landing fallback — use ONLY where overshoot would mislead (data bar widths, progress fills)."
      },
      "in-out": {
        "value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "type": "cubicBezier"
      },
      "spring": {
        "value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "type": "cubicBezier",
        "description": "Alias of ease.out — kept for legacy CSS references"
      }
    }
  },
  "_themes": {
    "$comment": "Future home of theme-light overrides (v0.9-P2-1 sand/cream palette). Phase A only ships the dark theme as the source of truth; light theme migration to this file is Phase A.1."
  }
}
