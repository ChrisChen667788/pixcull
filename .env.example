# v0.7-P2-3 — env scaffolding for scripts/release_macos.sh.
#
# Copy this file to .env (gitignored), fill in real values from
# docs/APPLE-DEVELOPER-SETUP.md, then `chmod 600 .env` to keep
# the secrets local to your machine.
#
# .env is loaded by release_macos.sh via `set -a; source .env; set +a`.

# Apple team ID (10 alphanumeric chars) — find via
#   security find-identity -v -p codesigning
APPLE_TEAM_ID=XXXXXXXXXX

# Code-signing identity string. Format:
#   "Developer ID Application: <Your Name> (TEAMID)"
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (XXXXXXXXXX)

# Keychain profile name created via
#   xcrun notarytool store-credentials pixcull-notary --apple-id ...
APPLE_NOTARY_PROFILE=pixcull-notary

# Sparkle EdDSA key account name passed to generate_keys + sign_update.
# Default "pixcull" matches docs/APPLE-DEVELOPER-SETUP.md.
SPARKLE_ED_ACCOUNT=pixcull
